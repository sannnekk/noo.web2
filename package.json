{
  "name": "noo.webui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "pnpm lint && run-p build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:ci": "vitest --run",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.json --composite false",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "run-s format:check lint type-check test:ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@duskmoon/vue3-typed-js": "^0.0.4",
    "@unovis/ts": "1.6.4",
    "@unovis/vue": "1.6.4",
    "@vueup/vue-quill": "1.2.0",
    "@vueuse/core": "^13.9.0",
    "animate.css": "^4.1.1",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "fast-json-patch": "github:sannnekk/JSON-Patch#feature/date-object-support",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.23",
    "mitt": "^3.0.1",
    "pinia": "^3.0.4",
    "quill": "^2.0.3",
    "tus-js-client": "^4.3.1",
    "vue": "^3.5.30",
    "vue-advanced-cropper": "^2.8.9",
    "vue-router": "^4.6.4",
    "vue-simple-calendar": "^7.2.1",
    "vue3-google-login": "^2.0.37",
    "vuedraggable": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@tsconfig/node18": "^18.2.6",
    "@types/js-cookie": "^3.0.6",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "8.34.1",
    "@typescript-eslint/parser": "8.34.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "9.29.0",
    "eslint-import-resolver-typescript": "4.4.3",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-vue": "10.2.0",
    "globals": "16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "~5.8.3",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "10.1.3",
    "vue-tsc": "^2.2.12"
  }
}